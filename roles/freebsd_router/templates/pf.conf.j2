# ==============================================================================
# --- 1. Macro & Tables (Definizioni) ---
# ==============================================================================
ext_if      = "{{ ext_if }}"
int_if      = "{{ int_if }}"
int_net     = "{{ int_net }}"
ssh_port    = "{{ ssh_port }}"
admin_ip    = "{{ admin_ip }}"
mumble_ip   = "{{ mumble_jail_ip }}"
mumble_port = "{{ mumble_port }}"
# Tabelle per una gestione dinamica e sicura
table <trusted_lan>   const { {{ admin_ip }}, 127.0.0.1 }
table <bruteforce>    persist
table <geo_countries> persist

# ==============================================================================
# --- 2. Options & Normalization ---
# ==============================================================================
set skip on lo0
set block-policy drop
set loginterface $ext_if

# Protezione contro frammentazione e pacchetti malformati
scrub in all fragment reassemble

# ==============================================================================
# --- 3. Translation (NAT & RDR) ---
# ==============================================================================
# NAT: Permette alla rete interna di uscire su Internet tramite l'IP della WAN
nat on $ext_if from $int_net to any -> ($ext_if) static-port
# Redirect Mumble
rdr on $ext_if proto { tcp, udp } from any to ($ext_if) port $mumble_port -> $mumble_ip

{% if gaming_host is defined and gaming_host | length > 0 %}
include "/etc/pf.anchors/gaming.rdr"
{% endif %}

{% if wg_peers is defined and wg_peers | length > 0 %}
include "/etc/pf.anchors/wg.nat"
{% endif %}

# ==============================================================================
# --- 4. Filtering Rules (Ordine: Block -> Pass) ---
# ==============================================================================

# Protezione anti-spoofing
antispoof quick for $ext_if
antispoof quick for $int_if

# --- A. Blocchi Immediati (Sicurezza) ---
block in quick from <bruteforce>
{% if wg_peers is defined and wg_peers | length > 0 %}
# Pass tunnel WireGuard PRIMA del geoblock: la VPN deve essere raggiungibile
# anche da paesi non in whitelist (uso in viaggio).
include "/etc/pf.anchors/wg.allow"
{% endif %}
{% if geoblock_mode == 'whitelist' %}
# Whitelist: il pass <trusted_lan> precede il block geo per evitare lockout admin
pass in quick on $ext_if from <trusted_lan>
block in quick on $ext_if from ! <geo_countries>
{% else %}
block in quick from <geo_countries>
{% endif %}
block in all

# --- B. Traffico in Uscita (Outbound) ---
# Permette al router stesso e alla LAN di generare traffico verso l'esterno
pass out all keep state

# --- C. Accesso ai Servizi Locali (Router) ---

# DHCP: Fondamentale per assegnare IP sulla rete interna (vtnet1)
# Il traffico deve essere accettato anche se il client non ha ancora un IP (any)
pass in quick on $int_if proto udp from any port 68 to 255.255.255.255 port 67
pass out quick on $int_if proto udp from $int_if port 67 to any port 68

# SSH: Accesso protetto da Admin sulla WAN
pass in quick on $ext_if proto tcp from <trusted_lan> to ($ext_if) port $ssh_port \
    flags S/SA keep state \
    (max-src-conn 5, max-src-conn-rate 3/30, overload <bruteforce> flush global)

# DNS (Unbound): Risoluzione per i client della rete interna
pass in quick on $int_if proto { tcp, udp } from $int_if:network to $int_if port 53 keep state

# ICMP: Permette ping e PMTUD (unreach/needfrag) per evitare connessioni appese
pass in quick on $int_if proto icmp from $int_if:network to $int_if icmp-type echoreq keep state
pass in quick on $ext_if inet proto icmp from <trusted_lan> to ($ext_if) icmp-type echoreq keep state
pass in quick inet proto icmp icmp-type unreach keep state

# --- D. Forwarding (Traffico verso i Server interni) ---

# Mumble: Accesso pubblico al server 10.0.0.x
# Niente overload<bruteforce>: client legittimi dietro NAT/CGNAT o in reconnect
# loop verrebbero bannati globalmente (SSH/web inclusi). Limiti permissivi —
# i nuovi stati oltre soglia vengono droppati solo per questa regola.
pass in quick on $ext_if proto tcp from any to $mumble_ip port $mumble_port \
    flags S/SA keep state \
    (max-src-conn 100, max-src-conn-rate 60/60, source-track rule)

pass in quick on $ext_if proto udp from any to $mumble_ip port $mumble_port \
    keep state (max-src-states 100, source-track rule)

# --- E. Forwarding Generale LAN (Traffico che attraversa il Router) ---
# Permette alla LAN di navigare su Internet
pass in on $int_if from $int_if:network to any keep state

{% if gaming_host is defined and gaming_host | length > 0 %}
include "/etc/pf.anchors/gaming.filter"
{% endif %}

{% if wg_peers is defined and wg_peers | length > 0 %}
include "/etc/pf.anchors/wg.filter"
{% endif %}
