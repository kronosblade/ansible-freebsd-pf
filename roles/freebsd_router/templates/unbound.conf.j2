server:
    verbosity: 1
    # Specifica ogni interfaccia su una riga separata
    interface: 127.0.0.1
    interface: {{ lan_ip | default('10.0.0.1') }}
{% if wg_peers is defined and wg_peers | length > 0 %}
    interface: {{ wg_server_address.split('/')[0] }}
    # ip-transparent permette il bind anche se wg0 non è ancora up al boot.
    # Necessario perché Unbound viene configurato prima della role wireguard.
    ip-transparent: yes
{% endif %}

    do-ip4: yes
    do-ip6: no
    do-udp: yes
    do-tcp: yes

    # Sicurezza: permetti esplicitamente localhost e la LAN interna
    access-control: 127.0.0.0/8 allow
    access-control: {{ lan_network | default('10.0.0.0/24') }} allow
{% if wg_peers is defined and wg_peers | length > 0 %}
    access-control: {{ wg_net }} allow
{% endif %}

    hide-identity: yes
    hide-version: yes

    # --- DNSSEC validation ---
    # Validator locale: difesa in profondità rispetto alla validazione fatta da
    # Quad9/Cloudflare upstream. Il trust anchor (root.key) viene inizializzato
    # da unbound-anchor al primo deploy e auto-aggiornato via RFC 5011.
    # Domini non firmati: risolti normalmente (val-permissive-mode no = strict
    # ma non blocca le risposte unsigned, blocca solo quelle signed-but-invalid).
    # Domini con DNSSEC rotto: SERVFAIL (comportamento corretto).
    module-config: "validator iterator"
    auto-trust-anchor-file: "/usr/local/etc/unbound/root.key"
    val-permissive-mode: no
    harden-dnssec-stripped: yes

    # Protezione DNS Rebinding: blocca risposte DNS pubbliche
    # che puntano a indirizzi IP privati
    private-address: 10.0.0.0/8
    private-address: 172.16.0.0/12
    private-address: 192.168.0.0/16
    private-address: 169.254.0.0/16
    private-address: fd00::/8
    private-address: fe80::/10

    # Performance
    prefetch: yes
    cache-min-ttl: 3600
    cache-max-ttl: 86400

    # Bundle certificati per validare i peer DoT upstream
    # Su FreeBSD è fornito dal port security/ca_root_nss (già presente nel base)
    tls-cert-bundle: "/etc/ssl/cert.pem"

forward-zone:
    name: "."
    # DNS-over-TLS: query cifrate verso Quad9 e Cloudflare
    forward-tls-upstream: yes
    forward-addr: 9.9.9.9@853#dns.quad9.net
    forward-addr: 1.1.1.1@853#cloudflare-dns.com
